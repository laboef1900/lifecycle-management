# ---- Local development (`pnpm dev`) ----
# apps/server/.env overrides these per-package; this file documents the shape.
DATABASE_URL=postgresql://lcm:lcm@localhost:5432/lcm
PORT=8090
LOG_LEVEL=info
NODE_ENV=development

# Optional hardening knobs (defaults shown; normally leave unset)
#CORS_ORIGIN=
#TRUST_PROXY=loopback,uniquelocal
#RATE_LIMIT_MAX=300

# Authentication (OIDC) is off by default — see the "Authentication (OIDC)"
# block below (it lives in the compose section since that's where it's
# deployed from) and docs/operations.md ("Enabling authentication").

# ---- Production docker compose ----
# Copy this file to `.env` and adjust before `docker compose up`.
# COMPOSE_FILE points the default `docker compose ...` lookup at the file in
# docker/, so you don't need `-f docker/docker-compose.yml` on every command.
COMPOSE_FILE=docker/docker-compose.yml

# Postgres credentials baked into both the db and server containers.
POSTGRES_USER=lcm
POSTGRES_PASSWORD=change-me-before-deploying
POSTGRES_DB=lcm

# Host port the web container exposes (maps to nginx 80 inside the container).
HTTP_PORT=80

# Set to `true` for the first boot so the server seeds reference data; flip
# back to false on subsequent restarts (seeding is idempotent but slow at
# startup).
SEED_ON_BOOT=false

# GHCR image tag to pull for the lcm-server + lcm-web containers. Defaults to
# `latest` (built from main). Use `dev` to track the dev branch, or a release
# tag like `0.1` to pin a specific release.
LCM_IMAGE_TAG=latest

# ---- Authentication (OIDC) ----
# Off by default. To enable: set AUTH_MODE=oidc plus every var down to
# LOGIN_STATE_SECRET, redeploy, then run the verification in
# docs/operations.md ("Enabling authentication") — a wrong/stale compose file
# silently leaves auth off.
#AUTH_MODE=disabled
#OIDC_ISSUER_URL=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#APP_BASE_URL=
# >=32 random chars; signs the short-lived login-state cookie only.
#LOGIN_STATE_SECRET=
#SESSION_TTL_HOURS=12
#OIDC_SCOPES=openid profile email
# Optional role mapping: claim name + CSV of values granting admin.
#OIDC_ROLE_CLAIM=
#OIDC_ADMIN_VALUES=
#OIDC_DEFAULT_ROLE=admin
# Optional access allowlist (CSV). Without it, IdP-side app assignment is the
# only access control — do not use public-signup IdPs without this.
#OIDC_ALLOWED_EMAIL_DOMAINS=
#OIDC_ALLOWED_EMAILS=
# Dev-only (local Keycloak/mock IdPs over http). Never in production.
#OIDC_ALLOW_INSECURE=false
