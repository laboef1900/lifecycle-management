{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // DOM provides the web-standard `URL` global (used by safeRedirectPath),
    // which both runtimes that consume this package — browser and Node — supply.
    "lib": ["ES2023", "DOM"],
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
