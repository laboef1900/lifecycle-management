# LCM web app — Vite-built React SPA served by nginx, with /api/* reverse
# proxied to the server. Uses Docker Hardened Images (DHI):
#
#   builder = dhi.io/node:22-alpine-dev (full shell + apk + corepack)
#   runtime = dhi.io/nginx:1            (distroless: only nginx + libs,
#                                        runs as uid 65532 nonroot,
#                                        listens on :8080)

# ----- builder -----
FROM dhi.io/node:22-alpine-dev AS builder

# The -dev builder image defaults to `node` (uid 1000) — upstream renamed
# it from `nonroot` in mid-2026.
USER root
# Pre-create the workdir owned by the build user — don't rely on the
# builder's WORKDIR-creation ownership behavior.
RUN corepack enable && install -d -o node -g node /repo
USER node

WORKDIR /repo

COPY --chown=node:node pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY --chown=node:node apps/server/package.json apps/server/
COPY --chown=node:node apps/web/package.json apps/web/
COPY --chown=node:node packages/shared/package.json packages/shared/

# --ignore-scripts skips @lcm/shared's `prepare` hook, which would try
# to tsc before we've copied sources. We build shared explicitly below
# once sources are in place.
RUN pnpm install --frozen-lockfile --ignore-scripts --filter @lcm/web...

COPY --chown=node:node tsconfig.base.json ./
COPY --chown=node:node packages/shared/src packages/shared/src
COPY --chown=node:node packages/shared/tsconfig.json packages/shared/tsconfig.build.json packages/shared/
COPY --chown=node:node apps/web/src apps/web/src
COPY --chown=node:node apps/web/index.html apps/web/vite.config.ts apps/web/tsconfig.json apps/web/
COPY --chown=node:node apps/web/public apps/web/public

# Vite resolves @lcm/shared via its package.json "exports" (→ dist/), so
# build shared first.
RUN pnpm --filter @lcm/shared build
RUN pnpm --filter @lcm/web build

# ----- runtime -----
FROM dhi.io/nginx:1 AS runtime

COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /repo/apps/web/dist /usr/share/nginx/html

# Listening port matches the `listen 8080` in nginx.conf — DHI's nginx
# can't bind privileged ports as nonroot.
EXPOSE 8080

# No HEALTHCHECK: the distroless runtime has no wget/curl/shell to probe
# itself. Compose's `depends_on` chain handles startup ordering;
# upstream liveness is the server container's responsibility.
