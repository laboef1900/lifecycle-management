# ---- Local development (`pnpm dev`) ----
# apps/server/.env overrides these per-package; this file documents the shape.
DATABASE_URL=postgresql://lcm:lcm@localhost:5432/lcm
PORT=8090
LOG_LEVEL=info
NODE_ENV=development

# Optional hardening knobs (defaults shown; normally leave unset)
#CORS_ORIGIN=
#TRUST_PROXY=loopback,uniquelocal
#RATE_LIMIT_MAX=300

# Authentication (OIDC) is off by default and is configured through the
# app's Settings → Authentication panel (DB-backed, encrypted at rest), not
# through env vars — see the "Authentication" block below (it lives in the
# compose section since that's where it's deployed from) and
# docs/operations.md ("Authentication (OIDC)").

# ---- Production docker compose ----
# Copy this file to `docker/.env` and adjust before running docker compose.
COMPOSE_FILE=docker-compose.yml

# Postgres credentials baked into both the db and server containers.
POSTGRES_USER=lcm
POSTGRES_PASSWORD=change-me-before-deploying
POSTGRES_DB=lcm

# Host port the web container exposes (maps to nginx 80 inside the container).
HTTP_PORT=80

# Set to `true` for the first boot so the server seeds reference data; flip
# back to false on subsequent restarts (seeding is idempotent but slow at
# startup).
SEED_ON_BOOT=false

# GHCR image tag to pull for the lcm-server + lcm-web containers. Defaults to
# `latest` (built from main). Use `dev` to track the dev branch, or a release
# tag like `0.1` to pin a specific release.
LCM_IMAGE_TAG=latest

# ---- Authentication ----
# OIDC config is DB-backed (an encrypted `auth_config` singleton row),
# managed from the running app's Settings → Authentication panel (admin
# only) — not by editing env vars and redeploying. See
# docs/operations.md ("Authentication (OIDC)") for the full picture.

# Required to use OIDC at all: encrypts the stored client secret + the
# app-generated login-state signing secret. Without it, OIDC seeds/stays
# disabled — the app fails safe, it never crashes for a missing key.
# Generate with: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=
# Losing this key, or changing it without a plan, means any previously
# stored OIDC secret can no longer be decrypted (an oidc-mode deployment
# is forced back to disabled automatically; local and disabled modes are
# unaffected — they never read the encrypted columns). See
# docs/operations.md ("CONFIG_ENCRYPTION_KEY rotation") before rotating it
# on a deployment that already has OIDC on.

# Emergency break-glass: set to `true` and restart to force auth off for
# that boot (e.g. you're locked out with no working admin session). The
# override is in-memory for that boot only and never rewrites the stored
# auth config — set this back to `false` (or unset) and restart, and the
# previously configured mode comes back on its own.
# See docs/operations.md ("Break-glass: RECOVERY_DISABLE_AUTH") — it also
# covers the mandatory post-episode account audit and the `curl` check
# that proves the API is closed again.
#RECOVERY_DISABLE_AUTH=false

# ---- OIDC seed vars (first boot only) ----
# SEED-ONLY: these are read exactly once, when the DB's auth_config table
# is still empty, to pre-populate the initial configuration (useful for
# unattended/first-boot provisioning). Once a config row exists — which
# happens on the very first boot regardless — every var below is ignored,
# even if you edit this file and restart. Configure OIDC afterwards in the
# app's Settings → Authentication, not here. Seeding a client secret still
# requires CONFIG_ENCRYPTION_KEY above; without it these seed as disabled.
# The client secret is only RETAINED when AUTH_MODE=oidc. This var accepts
# `oidc` or `disabled` only (`local` is not settable from env at all — it is
# configured in Settings → Authentication), and a seeded `disabled` row
# stores no secret: a non-oidc mode never reads the encrypted columns. Set
# AUTH_MODE=oidc below if you want the secret stored.
#AUTH_MODE=disabled
#OIDC_ISSUER_URL=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#APP_BASE_URL=
# Not read by the seeder — the login-state signing secret is generated by
# the app and stored (encrypted) in the DB; rotate it from Settings →
# Authentication instead. Kept here only for schema/back-compat validation.
#LOGIN_STATE_SECRET=
#SESSION_TTL_HOURS=12
#OIDC_SCOPES=openid profile email
# Optional role mapping: claim name + CSV of values granting admin.
#OIDC_ROLE_CLAIM=
#OIDC_ADMIN_VALUES=
#OIDC_DEFAULT_ROLE=admin
# Optional access allowlist (CSV). Without it, IdP-side app assignment is the
# only access control — do not use public-signup IdPs without this.
#OIDC_ALLOWED_EMAIL_DOMAINS=
#OIDC_ALLOWED_EMAILS=
# Dev-only knob for local Keycloak / mock IdPs served over http. It is read
# ONLY by `pnpm dev` (apps/server/.env) and is deliberately NOT forwarded by
# docker-compose — production/compose deployments must use an https issuer, so
# setting this in the compose .env has no effect.
#OIDC_ALLOW_INSECURE=false
