# Heavy directories that should never enter the build context
**/node_modules
**/dist
**/build
**/.next
**/.turbo
**/coverage
**/.cache

# pnpm metadata that doesn't need to ship to the image
.pnpm-store

# Source control + CI
.git
.github
.husky

# Editor / OS
.idea
.vscode
.DS_Store
Thumbs.db

# Local secrets and host-only env files (we want .env.example only)
.env
.env.*
!.env.example
apps/server/.env
apps/web/.env

# Logs and ephemeral artifacts
*.log
logs/
**/test-results
**/playwright-report
.playwright-mcp

# Generated by tools (regenerated on container build)
apps/web/src/routeTree.gen.ts

# Documentation that shouldn't bloat the image
apps/web/docs
docs/Capacity_Forecast_vSphere.xlsx
