// LCM v1 — data model
// Spec: docs/superpowers/specs/2026-05-22-lcm-v1-design.md

generator client {
  // Prisma 7 ships a Rust-free client (WASM query compiler + a JS driver
  // adapter), so there is no native query-engine binary and `binaryTargets`
  // is obsolete — the pure-JS `@prisma/adapter-pg` runs identically on
  // musl amd64/arm64, which is what the old OpenSSL pinning worked around.
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7 no longer accepts `url` here; the connection string lives in
  // prisma.config.ts (for the CLI) and is passed to PrismaClient via the
  // `@prisma/adapter-pg` driver adapter at runtime.
  provider = "postgresql"
}

// ---------- Lookup ----------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clusters            Cluster[]
  baselines           ClusterMetricBaseline[]
  hosts               Host[]
  hostCapacities      HostMetricCapacity[]
  hostLifecycleEvents HostLifecycleEvent[]
  hostReplacements    HostReplacement[]
  items               Item[]
  itemAllocations     ItemAllocation[]
  categories          Category[]
  settings            TenantSettings?
  users               User[]

  @@map("tenants")
}

model TenantSettings {
  tenantId                 String   @id @map("tenant_id")
  warnThreshold            Decimal  @default(0.70) @map("warn_threshold") @db.Decimal(4, 3)
  critThreshold            Decimal  @default(0.90) @map("crit_threshold") @db.Decimal(4, 3)
  procurementLeadTimeWeeks Int      @default(8) @map("procurement_lead_time_weeks")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model MetricType {
  id          String @id @default(cuid())
  key         String @unique
  displayName String @map("display_name")
  unit        String

  baselines       ClusterMetricBaseline[]
  hostCapacities  HostMetricCapacity[]
  itemAllocations ItemAllocation[]
  items           Item[]

  @@map("metric_types")
}

// ---------- Cluster + baselines ----------

model Cluster {
  id           String    @id @default(cuid())
  tenantId     String    @default("default") @map("tenant_id")
  name         String
  description  String?
  baselineDate DateTime  @map("baseline_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  archivedAt   DateTime? @map("archived_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  baselines ClusterMetricBaseline[]
  hosts     Host[]
  items     Item[]
  settings  ClusterSettings?

  @@unique([tenantId, name], map: "clusters_tenant_name_unique")
  @@map("clusters")
}

model ClusterSettings {
  clusterId     String   @id @map("cluster_id")
  warnThreshold Decimal? @map("warn_threshold") @db.Decimal(4, 3)
  critThreshold Decimal? @map("crit_threshold") @db.Decimal(4, 3)
  updatedAt     DateTime @updatedAt @map("updated_at")

  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@map("cluster_settings")
}

model ClusterMetricBaseline {
  clusterId           String  @map("cluster_id")
  metricTypeId        String  @map("metric_type_id")
  tenantId            String  @default("default") @map("tenant_id")
  baselineConsumption Decimal @map("baseline_consumption") @db.Decimal(18, 3)
  baselineCapacity    Decimal @map("baseline_capacity") @db.Decimal(18, 3)

  cluster    Cluster    @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@id([clusterId, metricTypeId])
  @@map("cluster_metric_baselines")
}

// ---------- Hosts (capacity providers) ----------

model Host {
  id               String    @id @default(cuid())
  tenantId         String    @default("default") @map("tenant_id")
  clusterId        String    @map("cluster_id")
  name             String
  description      String?
  commissionedAt   DateTime  @map("commissioned_at") @db.Date
  decommissionedAt DateTime? @map("decommissioned_at") @db.Date
  serialNumber     String?   @map("serial_number")
  vendor           String?
  model            String?
  purchasedAt      DateTime? @map("purchased_at") @db.Date
  warrantyEndsAt   DateTime? @map("warranty_ends_at") @db.Date
  eolAt            DateTime? @map("eol_at") @db.Date
  runPastEol       Boolean   @default(false) @map("run_past_eol")
  state            HostState @default(in_service)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  cluster         Cluster              @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  capacities      HostMetricCapacity[]
  lifecycleEvents HostLifecycleEvent[]
  replacedByLinks HostReplacement[]    @relation("HostReplacementOld")
  replacesLinks   HostReplacement[]    @relation("HostReplacementNew")

  /// Uniqueness is enforced via a partial unique index in the migration —
  /// Prisma can't express `WHERE serial_number IS NOT NULL` natively, so we
  /// declare a non-unique index here just to reserve the name.
  @@index([tenantId, serialNumber], map: "hosts_tenant_serial_unique")
  @@index([clusterId])
  @@index([state])
  @@index([eolAt])
  @@map("hosts")
}

enum HostState {
  ordered
  racked
  in_service
  degraded
  decommissioned
  disposed

  @@map("host_state")
}

model HostLifecycleEvent {
  id         String     @id @default(cuid())
  tenantId   String     @default("default") @map("tenant_id")
  hostId     String     @map("host_id")
  fromState  HostState? @map("from_state")
  toState    HostState  @map("to_state")
  occurredAt DateTime   @map("occurred_at") @db.Date
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at")

  host   Host   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([hostId, occurredAt])
  @@map("host_lifecycle_events")
}

model HostReplacement {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  oldHostId String   @map("old_host_id")
  newHostId String   @map("new_host_id")
  swappedAt DateTime @map("swapped_at") @db.Date
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  old    Host   @relation("HostReplacementOld", fields: [oldHostId], references: [id], onDelete: Cascade)
  new    Host   @relation("HostReplacementNew", fields: [newHostId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([oldHostId, newHostId])
  @@index([swappedAt])
  @@map("host_replacements")
}

model HostMetricCapacity {
  id            String   @id @default(cuid())
  hostId        String   @map("host_id")
  metricTypeId  String   @map("metric_type_id")
  tenantId      String   @default("default") @map("tenant_id")
  effectiveFrom DateTime @map("effective_from") @db.Date
  amount        Decimal  @db.Decimal(18, 3)
  createdAt     DateTime @default(now()) @map("created_at")

  host       Host       @relation(fields: [hostId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([hostId, metricTypeId, effectiveFrom])
  @@map("host_metric_capacities")
}

// ---------- Items (unified applications + events) ----------

enum ItemKind {
  application
  event

  @@map("item_kind")
}

model Item {
  id               String    @id @default(cuid())
  tenantId         String    @default("default") @map("tenant_id")
  clusterId        String    @map("cluster_id")
  kind             ItemKind  @default(application)
  name             String
  category         String
  description      String?
  effectiveDate    DateTime  @map("effective_date") @db.Date
  endedAt          DateTime? @map("ended_at") @db.Date
  metricTypeId     String?   @map("metric_type_id")
  consumptionDelta Decimal?  @map("consumption_delta") @db.Decimal(18, 3)
  capacityDelta    Decimal?  @map("capacity_delta") @db.Decimal(18, 3)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  cluster     Cluster          @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  metricType  MetricType?      @relation(fields: [metricTypeId], references: [id], onDelete: Restrict)
  allocations ItemAllocation[]

  @@index([clusterId])
  @@index([clusterId, effectiveDate])
  @@map("items")
}

model ItemAllocation {
  id            String   @id @default(cuid())
  itemId        String   @map("item_id")
  metricTypeId  String   @map("metric_type_id")
  tenantId      String   @default("default") @map("tenant_id")
  effectiveFrom DateTime @map("effective_from") @db.Date
  amount        Decimal  @db.Decimal(18, 3)
  createdAt     DateTime @default(now()) @map("created_at")

  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([itemId, metricTypeId, effectiveFrom])
  @@map("item_allocations")
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name], map: "categories_tenant_name_unique")
  @@map("categories")
}

// ---------- Auth ----------

model User {
  id          String    @id @default(cuid())
  tenantId    String    @default("default") @map("tenant_id")
  issuer      String
  subject     String
  email       String?
  displayName String?   @map("display_name")
  role        UserRole  @default(VIEWER)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([issuer, subject])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuthConfig {
  id                  String   @id @default("singleton")
  mode                String   @default("disabled")
  issuerUrl           String?  @map("issuer_url")
  clientId            String?  @map("client_id")
  clientSecretEnc     String?  @map("client_secret_enc")
  signingSecretEnc    String?  @map("signing_secret_enc")
  appBaseUrl          String?  @map("app_base_url")
  scopes              String   @default("openid profile email")
  roleClaim           String?  @map("role_claim")
  adminValues         String?  @map("admin_values")
  defaultRole         String   @default("admin") @map("default_role")
  allowedEmailDomains String?  @map("allowed_email_domains")
  allowedEmails       String?  @map("allowed_emails")
  sessionTtlHours     Int      @default(12) @map("session_ttl_hours")
  allowInsecure       Boolean  @default(false) @map("allow_insecure")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedByUserId     String?  @map("updated_by_user_id")

  @@map("auth_config")
}

enum UserRole {
  ADMIN
  VIEWER
}
