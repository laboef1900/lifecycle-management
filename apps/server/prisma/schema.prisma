// LCM v1 — data model
// Spec: docs/superpowers/specs/2026-05-22-lcm-v1-design.md

generator client {
  // Prisma 7 ships a Rust-free client (WASM query compiler + a JS driver
  // adapter), so there is no native query-engine binary and `binaryTargets`
  // is obsolete — the pure-JS `@prisma/adapter-pg` runs identically on
  // musl amd64/arm64, which is what the old OpenSSL pinning worked around.
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7 no longer accepts `url` here; the connection string lives in
  // prisma.config.ts (for the CLI) and is passed to PrismaClient via the
  // `@prisma/adapter-pg` driver adapter at runtime.
  provider = "postgresql"
}

// ---------- Lookup ----------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clusters            Cluster[]
  baselines           ClusterMetricBaseline[]
  baselineHistory     ClusterBaselineHistory[]
  vsphereConnections  VsphereConnection[]
  hosts               Host[]
  hostCapacities      HostMetricCapacity[]
  hostLifecycleEvents HostLifecycleEvent[]
  hostReplacements    HostReplacement[]
  items               Item[]
  itemAllocations     ItemAllocation[]
  categories          Category[]
  settings            TenantSettings?
  users               User[]

  @@map("tenants")
}

model TenantSettings {
  tenantId                 String   @id @map("tenant_id")
  warnThreshold            Decimal  @default(0.70) @map("warn_threshold") @db.Decimal(4, 3)
  critThreshold            Decimal  @default(0.90) @map("crit_threshold") @db.Decimal(4, 3)
  procurementLeadTimeWeeks Int      @default(8) @map("procurement_lead_time_weeks")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model MetricType {
  id          String @id @default(cuid())
  key         String @unique
  displayName String @map("display_name")
  unit        String

  baselines       ClusterMetricBaseline[]
  baselineHistory ClusterBaselineHistory[]
  hostCapacities  HostMetricCapacity[]
  itemAllocations ItemAllocation[]
  items           Item[]

  @@map("metric_types")
}

// ---------- Cluster + baselines ----------

model Cluster {
  id           String    @id @default(cuid())
  /// 'manual' | 'vsphere'. Defaults to manual, so the migration is a pure additive
  /// column default: every existing cluster stays manual and untouched.
  source       String    @default("manual")
  /// The vCenter this cluster came from. onDelete: Restrict is deliberate and
  /// load-bearing — see the VsphereConnection relation below.
  connectionId String?   @map("vsphere_connection_id")
  /// vCenter MoRef, e.g. `domain-c123`. Stable across renames; NOT stable across a
  /// vCenter rebuild — which is what VsphereConnection.instanceUuid catches.
  externalId   String?   @map("external_id")
  /// The cluster's name in vCenter, verbatim and sync-owned. `name` is LCM's own
  /// editable label: two vCenters may both have a cluster called "Production", and
  /// the operator must be able to tell them apart in the fleet console.
  externalName String?   @map("external_name")
  /// Set once an operator edits `name`. Sync then never touches the label again —
  /// a vCenter-side rename updates `externalName` and is surfaced as a hint rather
  /// than clobbering a deliberate choice.
  nameIsCustom Boolean   @default(false) @map("name_is_custom")
  lastSyncedAt DateTime? @map("last_synced_at")
  tenantId     String    @default("default") @map("tenant_id")
  name         String
  description  String?
  baselineDate DateTime  @map("baseline_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  archivedAt   DateTime? @map("archived_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// @ai-warning `onDelete: Restrict`, NEVER Cascade. ClusterMetricBaseline and
  /// ClusterBaselineHistory both cascade from Cluster, so a cascade here would
  /// chain: delete connection -> delete clusters -> DELETE EVERY BASELINE. One
  /// misclick in Settings would silently destroy the purchasing history this whole
  /// epic exists to accumulate, and it would not even look destructive at the click
  /// site. Restrict makes the database refuse; the API returns 409 and offers an
  /// explicit detach that converts the clusters to manual and keeps every row.
  ///
  /// SetNull is also wrong: it would leave source='vsphere' with a null
  /// connectionId — a row no code path expects — and would make the destructive
  /// path automatic rather than deliberate.
  connection      VsphereConnection?       @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  baselines       ClusterMetricBaseline[]
  baselineHistory ClusterBaselineHistory[]
  hosts           Host[]
  items           Item[]
  settings        ClusterSettings?

  @@unique([tenantId, name], map: "clusters_tenant_name_unique")
  /// Cluster identity WITHIN a vCenter. A MoRef (`domain-c123`) is unique only
  /// inside one vCenter, so it is meaningless without the connection — hence the
  /// composite. Matching on NAME instead would treat a vCenter-side rename as
  /// delete+create and DESTROY the baseline history; MoRefs survive renames.
  ///
  /// Both columns are NULL for manual clusters, and Postgres treats NULLs as
  /// distinct, so every manual cluster coexists here (the same property
  /// hosts_tenant_serial_unique relies on).
  @@unique([connectionId, externalId], map: "clusters_connection_external_unique")
  @@map("clusters")
}

model ClusterSettings {
  clusterId     String   @id @map("cluster_id")
  warnThreshold Decimal? @map("warn_threshold") @db.Decimal(4, 3)
  critThreshold Decimal? @map("crit_threshold") @db.Decimal(4, 3)
  updatedAt     DateTime @updatedAt @map("updated_at")

  cluster Cluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@map("cluster_settings")
}

model ClusterMetricBaseline {
  clusterId           String  @map("cluster_id")
  metricTypeId        String  @map("metric_type_id")
  tenantId            String  @default("default") @map("tenant_id")
  baselineConsumption Decimal @map("baseline_consumption") @db.Decimal(18, 3)
  baselineCapacity    Decimal @map("baseline_capacity") @db.Decimal(18, 3)

  cluster    Cluster    @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@id([clusterId, metricTypeId])
  @@map("cluster_metric_baselines")
}

/// Append-only baseline history — the source of truth for the forecast anchor
/// and the chart's historical series (#177).
///
/// @ai-warning `capturedAt` IS the period anchor, not merely "when we measured".
/// Both manual entry and the vSphere snapshot job snap it to the first of the
/// month, so `@@unique([clusterId, metricTypeId, capturedAt])` *is* monthly
/// idempotency, enforced by Postgres rather than by application logic. A job that
/// restarts and re-runs on a different day of the same month recomputes the same
/// key and conflicts. Do not "fix" this to a timestamp — that silently drops the
/// guarantee to day-granularity and lets one month hold two competing truths.
/// `observedAt` carries the real instant, is informational only, and is read by
/// nothing on the forecast path.
///
/// @ai-context `source` is deliberately NOT in the unique key. Including it would
/// let a manual row and a vsphere row coexist for one period, making "the newest
/// baseline" ambiguous on the number that drives hardware purchasing. Excluding it
/// means exactly one truth per metric per period, and an admin correcting a bad
/// sync is an explicit overwrite that flips `source` to manual.
model ClusterBaselineHistory {
  id                  String    @id @default(cuid())
  clusterId           String    @map("cluster_id")
  metricTypeId        String    @map("metric_type_id")
  tenantId            String    @default("default") @map("tenant_id")
  capturedAt          DateTime  @map("captured_at") @db.Date
  source              String    @default("manual")
  observedAt          DateTime? @map("observed_at") @db.Timestamptz(3)
  baselineConsumption Decimal   @map("baseline_consumption") @db.Decimal(18, 3)
  baselineCapacity    Decimal   @map("baseline_capacity") @db.Decimal(18, 3)
  createdAt           DateTime  @default(now()) @map("created_at")

  cluster    Cluster    @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([clusterId, metricTypeId, capturedAt], map: "cluster_baseline_history_period_unique")
  @@map("cluster_baseline_history")
}

// ---------- Hosts (capacity providers) ----------

model Host {
  id                        String    @id @default(cuid())
  source                    String    @default("manual")
  connectionId              String?   @map("vsphere_connection_id")
  externalId                String?   @map("external_id")
  externalName              String?   @map("external_name")
  lastSyncedAt              DateTime? @map("last_synced_at")
  /// @ai-warning vCenter cannot tell us when a host was commissioned, so sync
  /// imports a PROVISIONAL date and flags it. This matters more than it looks:
  /// effectiveCapacityAt returns 0 before commissionedAt, and a wrong date silently
  /// zeroes a host's capacity for every month before it — which the forecast then
  /// renders as "unknown" utilization. The operator confirms the real date after
  /// import (owner decision Q9c).
  commissionedAtProvisional Boolean   @default(false) @map("commissioned_at_provisional")
  tenantId                  String    @default("default") @map("tenant_id")
  clusterId                 String    @map("cluster_id")
  name                      String
  description               String?
  commissionedAt            DateTime  @map("commissioned_at") @db.Date
  decommissionedAt          DateTime? @map("decommissioned_at") @db.Date
  serialNumber              String?   @map("serial_number")
  vendor                    String?
  model                     String?
  purchasedAt               DateTime? @map("purchased_at") @db.Date
  warrantyEndsAt            DateTime? @map("warranty_ends_at") @db.Date
  eolAt                     DateTime? @map("eol_at") @db.Date
  runPastEol                Boolean   @default(false) @map("run_past_eol")
  state                     HostState @default(in_service)
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  cluster         Cluster              @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  capacities      HostMetricCapacity[]
  lifecycleEvents HostLifecycleEvent[]
  replacedByLinks HostReplacement[]    @relation("HostReplacementOld")
  replacesLinks   HostReplacement[]    @relation("HostReplacementNew")
  /// @ai-warning onDelete: Restrict, NEVER Cascade — same reasoning as the Cluster
  /// relation. A synced host carries HostMetricCapacity rows that feed the forecast;
  /// cascading a connection delete into them would silently change fleet capacity.
  connection      VsphereConnection?   @relation(fields: [connectionId], references: [id], onDelete: Restrict)

  /// Per-tenant uniqueness of serial numbers. Declared as a full unique index
  /// (not the historical partial `WHERE serial_number IS NOT NULL`): Postgres
  /// treats NULLs as distinct, so NULL-serial rows never conflict under either
  /// form — they are equivalent here, and `@@unique` is expressible natively so
  /// schema and DB agree (no more spurious `migrate dev` index drift, #123).
  /// Host identity within a vCenter — same reasoning as clusters_connection_external_unique.
  @@unique([connectionId, externalId], map: "hosts_connection_external_unique")
  @@unique([tenantId, serialNumber], map: "hosts_tenant_serial_unique")
  @@index([clusterId])
  @@index([state])
  @@index([eolAt])
  @@map("hosts")
}

enum HostState {
  ordered
  racked
  in_service
  degraded
  decommissioned
  disposed

  @@map("host_state")
}

model HostLifecycleEvent {
  id         String     @id @default(cuid())
  tenantId   String     @default("default") @map("tenant_id")
  hostId     String     @map("host_id")
  fromState  HostState? @map("from_state")
  toState    HostState  @map("to_state")
  occurredAt DateTime   @map("occurred_at") @db.Date
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at")

  host   Host   @relation(fields: [hostId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([hostId, occurredAt])
  @@map("host_lifecycle_events")
}

model HostReplacement {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  oldHostId String   @map("old_host_id")
  newHostId String   @map("new_host_id")
  swappedAt DateTime @map("swapped_at") @db.Date
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  old    Host   @relation("HostReplacementOld", fields: [oldHostId], references: [id], onDelete: Cascade)
  new    Host   @relation("HostReplacementNew", fields: [newHostId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([oldHostId, newHostId])
  @@index([swappedAt])
  @@map("host_replacements")
}

model HostMetricCapacity {
  id            String   @id @default(cuid())
  hostId        String   @map("host_id")
  metricTypeId  String   @map("metric_type_id")
  tenantId      String   @default("default") @map("tenant_id")
  effectiveFrom DateTime @map("effective_from") @db.Date
  amount        Decimal  @db.Decimal(18, 3)
  createdAt     DateTime @default(now()) @map("created_at")

  host       Host       @relation(fields: [hostId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([hostId, metricTypeId, effectiveFrom])
  @@map("host_metric_capacities")
}

// ---------- Items (unified applications + events) ----------

enum ItemKind {
  application
  event

  @@map("item_kind")
}

model Item {
  id               String    @id @default(cuid())
  tenantId         String    @default("default") @map("tenant_id")
  clusterId        String    @map("cluster_id")
  kind             ItemKind  @default(application)
  name             String
  category         String
  description      String?
  effectiveDate    DateTime  @map("effective_date") @db.Date
  endedAt          DateTime? @map("ended_at") @db.Date
  metricTypeId     String?   @map("metric_type_id")
  consumptionDelta Decimal?  @map("consumption_delta") @db.Decimal(18, 3)
  capacityDelta    Decimal?  @map("capacity_delta") @db.Decimal(18, 3)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  cluster     Cluster          @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  metricType  MetricType?      @relation(fields: [metricTypeId], references: [id], onDelete: Restrict)
  allocations ItemAllocation[]

  @@index([clusterId])
  @@index([clusterId, effectiveDate])
  @@map("items")
}

model ItemAllocation {
  id            String   @id @default(cuid())
  itemId        String   @map("item_id")
  metricTypeId  String   @map("metric_type_id")
  tenantId      String   @default("default") @map("tenant_id")
  effectiveFrom DateTime @map("effective_from") @db.Date
  amount        Decimal  @db.Decimal(18, 3)
  createdAt     DateTime @default(now()) @map("created_at")

  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  metricType MetricType @relation(fields: [metricTypeId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([itemId, metricTypeId, effectiveFrom])
  @@map("item_allocations")
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String   @default("default") @map("tenant_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name], map: "categories_tenant_name_unique")
  @@map("categories")
}

// ---------- Auth ----------

model User {
  id          String    @id @default(cuid())
  tenantId    String    @default("default") @map("tenant_id")
  issuer      String
  subject     String
  email       String?
  displayName String?   @map("display_name")
  role        UserRole  @default(VIEWER)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  passwordHash        String?   @map("password_hash")
  passwordUpdatedAt   DateTime? @map("password_updated_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  disabled            Boolean   @default(false)

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([issuer, subject])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Postgres does not auto-index FK columns; index user_id so per-user session
  // lookups and the ON DELETE CASCADE from users don't sequential-scan sessions.
  @@index([userId])
  @@map("sessions")
}

model AuthConfig {
  id                  String   @id @default("singleton")
  mode                String   @default("disabled")
  issuerUrl           String?  @map("issuer_url")
  clientId            String?  @map("client_id")
  clientSecretEnc     String?  @map("client_secret_enc")
  signingSecretEnc    String?  @map("signing_secret_enc")
  appBaseUrl          String?  @map("app_base_url")
  scopes              String   @default("openid profile email")
  roleClaim           String?  @map("role_claim")
  adminValues         String?  @map("admin_values")
  defaultRole         String   @default("admin") @map("default_role")
  allowedEmailDomains String?  @map("allowed_email_domains")
  allowedEmails       String?  @map("allowed_emails")
  sessionTtlHours     Int      @default(12) @map("session_ttl_hours")
  allowInsecure       Boolean  @default(false) @map("allow_insecure")
  updatedAt           DateTime @updatedAt @map("updated_at")
  updatedByUserId     String?  @map("updated_by_user_id")

  @@map("auth_config")
}

enum UserRole {
  ADMIN
  VIEWER
}

/// A configured vCenter, one row per instance (#175, epic #172).
///
/// @ai-warning This is NOT a singleton, and must not be "simplified" into one to
/// match AuthConfig. The deployment has two or more vCenters, and the AuthConfig
/// pattern does not transfer for two further reasons: degrade must be
/// PER-CONNECTION (one undecryptable secret must not disable the others), and the
/// decrypted secret must NOT be cached — AuthConfig caches because it sits on the
/// hot path of every request, whereas these credentials are used by a background
/// job every few minutes, so decrypt-on-use is affordable and keeps plaintext out
/// of the long-lived heap.
///
/// @ai-warning `passwordEnc` is the ONLY secret here. `tlsPinnedCaPem` and its
/// fingerprint are PUBLIC certificate data — vCenter serves the CA unauthenticated
/// and presents it in every handshake — so encrypting them would protect a secret
/// that does not exist.
model VsphereConnection {
  id          String @id @default(cuid())
  tenantId    String @default("default") @map("tenant_id")
  name        String
  /// Bare hostname. The scheme and port are fixed server-side (https, 443) so a
  /// URL can never be smuggled through this column.
  hostname    String
  username    String
  /// AES-GCM under CONFIG_ENCRYPTION_KEY via crypto/secret-box.ts — reused as-is,
  /// no new crypto. On a decrypt failure this column is NEVER nulled: the
  /// ciphertext may be the only copy, and restoring the key recovers it. Same rule
  /// and same reasoning as AuthConfig (plugins/auth-config.ts).
  passwordEnc String @map("password_enc")

  /// 'system' | 'pinned'. Exactly two values, both fail closed. There is no
  /// insecure mode and there must never be one — see the shared contract.
  tlsMode         String  @default("pinned") @map("tls_mode")
  /// The pinned trust anchor: the ROOT of the presented chain, not the leaf.
  /// vCenter auto-renews its leaf unattended, so a leaf pin would break by itself
  /// on a ~2-year timer. Public data, stored in plaintext.
  tlsPinnedCaPem  String? @map("tls_pinned_ca_pem")
  tlsPinnedSha256 String? @map("tls_pinned_sha256")

  /// ServiceContent.about.instanceUuid, discovered on connect — never entered by
  /// an operator.
  ///
  /// @ai-warning This is the guard against silent cross-vCenter corruption. MoRefs
  /// are unique only WITHIN a vCenter, so if this hostname is ever re-pointed (DNS
  /// change, DR failover, a rebuilt appliance reusing the name), `domain-c123` at
  /// the new target is a COMPLETELY DIFFERENT cluster — and sync would overwrite
  /// the wrong cluster's hosts and capacity, feeding wrong numbers into a forecast
  /// that buys hardware. On mismatch: refuse to sync, never auto-heal.
  instanceUuid String? @map("instance_uuid")
  apiVersion   String? @map("api_version")

  enabled         Boolean   @default(true)
  status          String    @default("never_connected")
  /// Sanitized before storage — never a raw driver error, never secret-bearing.
  lastError       String?   @map("last_error")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clusters Cluster[]
  hosts    Host[]
  job      VsphereConnectionJob?

  @@unique([tenantId, name])
  /// Stops the same vCenter being added twice under two names (FQDN and IP), which
  /// would import every cluster twice and silently DOUBLE fleet capacity. NULLs are
  /// distinct in Postgres, so many not-yet-connected rows coexist — the same
  /// property hosts_tenant_serial_unique already relies on.
  @@unique([tenantId, instanceUuid], map: "vsphere_connections_tenant_instance_unique")
  @@map("vsphere_connections")
}

/// Scheduling state for one vCenter connection (#178, epic #172).
///
/// @ai-warning `connectionId` is BOTH primary key and foreign key. That is not
/// tidiness — it is what makes the whole design work:
///   - one claim per connection ⇒ intra-connection concurrency is STRUCTURALLY
///     impossible rather than defended against, and "sync before snapshot" becomes
///     sequential statements in one job body with no cross-job race to reason about;
///   - the FK cascades, so a deleted connection cannot leave an orphan row ticking
///     and failing forever against a vCenter that no longer exists.
///
/// @ai-context Cascade here does NOT contradict the Restrict on Cluster.connection.
/// The rule is: **cascade is correct for regenerable operational state; forbidden
/// for irreplaceable user data.** This row is pure derived state — the next tick
/// rebuilds it. A baseline is irreplaceable: a destroyed August cannot be
/// re-measured, the moment is gone.
model VsphereConnectionJob {
  connectionId String    @id @map("vsphere_connection_id")
  /// The single scheduling primitive. `dueAt <= now()` IS catch-up: server down
  /// three days ⇒ dueAt two days past ⇒ the first tick after boot runs it. There is
  /// deliberately no "did I miss one?" branch to get wrong.
  dueAt        DateTime  @map("due_at")
  /// Claim lease. Non-null means someone is running it; a stale lease is reclaimed
  /// so a hard-killed process self-heals instead of wedging forever.
  runningSince DateTime? @map("running_since")
  lockedBy     String?   @map("locked_by")
  failureCount Int       @default(0) @map("failure_count")

  lastPollAt         DateTime? @map("last_poll_at")
  lastSyncAt         DateTime? @map("last_sync_at")
  lastSyncStatus     String?   @map("last_sync_status")
  lastSnapshotAt     DateTime? @map("last_snapshot_at")
  lastSnapshotStatus String?   @map("last_snapshot_status")
  /// The period the last snapshot ATTEMPTED.
  lastSnapshotPeriod DateTime? @map("last_snapshot_period") @db.Date
  /// The period the last snapshot SUCCEEDED for. Distinct from the above on
  /// purpose: comparing them at recovery is how a missed month becomes visible
  /// ("Missed: Aug 2026") rather than merely absent from a chart.
  lastSuccessPeriod  DateTime? @map("last_success_period") @db.Date
  lastError          String?   @map("last_error")

  connection VsphereConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([dueAt])
  @@map("vsphere_connection_jobs")
}
